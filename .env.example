# Plantilla de variables de entorno. Copiar a .env y rellenar con valores reales.
#   Windows:  copy .env.example .env
#   Linux/Mac: cp .env.example .env
# El archivo .env NO se versiona (ver .gitignore).
# El instalador (instalar_crai.bat) crea este .env automáticamente y genera la
# SECRET_KEY por ti; solo tendrás que ajustar la contraseña de PostgreSQL.

# ==================== DJANGO ====================
# Clave secreta de Django. Generar una nueva con:
#   python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=cambia-esto-por-una-clave-secreta

# ==================== BASE DE DATOS (PostgreSQL) ====================
# Debes tener PostgreSQL instalado y la base de datos creada (ver README).
# Ajusta DB_PASSWORD a la contraseña de TU usuario postgres.
DB_NAME=crai_unemi
DB_USER=postgres
DB_PASSWORD=1508
DB_HOST=localhost
DB_PORT=5432

# ==================== CORREO (Gmail SMTP) ====================
# EMAIL_HOST_USER: la cuenta de Gmail que envía los correos.
# EMAIL_HOST_PASSWORD: App Password de 16 caracteres (NO la contraseña normal).
#   Generar en: https://myaccount.google.com/apppasswords
# Opcional para desarrollo: si lo dejas vacío, la recuperación de contraseña
# por correo no funcionará, pero el resto del sistema sí.
EMAIL_HOST_USER=tu-correo@gmail.com
EMAIL_HOST_PASSWORD=xxxxxxxxxxxxxxxx
DEFAULT_FROM_EMAIL=CRAI UNEMI <tu-correo@gmail.com>

# ==================== API EXTERNA DE MATRÍCULAS ====================
# Servicio que simula el sistema de matrículas (fuente de verdad de estudiantes).
# Opcional: si no lo tienes corriendo, usa los datos de demo (datos_demo.json).
API_MATRICULAS_BASE_URL=http://127.0.0.1:8001/api
API_MATRICULAS_KEY=clave-dev-compartida
API_MATRICULAS_TIMEOUT=5

# ==================== N8N CHATBOT ====================
N8N_CHATBOT_WEBHOOK_URL=http://localhost:5678/webhook/crai-chatbot
N8N_API_KEY=clave-n8n-dev

# ==================== APP KIOSKO CHROMEBOOK ====================
# Clave compartida que la app de cada Chromebook envía en el header 'X-KIOSKO-KEY'.
KIOSKO_API_KEY=clave-kiosko-dev

# ==================== WHATSAPP CLOUD API (Meta) ====================
# Opcional: solo si vas a usar el chatbot por WhatsApp.
WHATSAPP_VERIFY_TOKEN=crai-verify-2026
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=1087899717740956
WHATSAPP_API_VERSION=v21.0
# Número visible del bot (formato internacional sin '+', ej. 5939XXXXXXXX) para
# el botón "Chatea por WhatsApp" del portal del estudiante.
WHATSAPP_NUMERO=
