<?xml version="1.0" encoding="utf-8"?>
<!--
  Política de administrador de dispositivo. No pedimos capacidades intrusivas:
  con solo estar ACTIVO como device admin, Android impide que se desinstale la
  app hasta que el personal lo desactive a propósito (Ajustes → Seguridad →
  Apps de administración). Es un "estorbo" para el estudiante, no un candado
  absoluto (en Chromebook NO administrada no existe el candado absoluto).
-->
<device-admin xmlns:android="http://schemas.android.com/apk/res/android">
    <uses-policies>
        <force-lock />
    </uses-policies>
</device-admin>
