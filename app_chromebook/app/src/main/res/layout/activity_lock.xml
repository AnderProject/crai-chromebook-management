<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/rojo">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:id="@+id/lockIcono"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🔒"
            android:textSize="72sp" />

        <TextView
            android:id="@+id/lockTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:text="@string/lock_titulo"
            android:textColor="@color/blanco"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/txtLockMsg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:gravity="center"
            android:text="@string/lock_mensaje"
            android:textColor="@color/blanco"
            android:textSize="18sp" />
    </LinearLayout>

    <!-- Botón discreto para que el personal del CRAI desbloquee con PIN -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnDesbloquear"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginBottom="16dp"
        android:alpha="0.7"
        android:text="@string/lock_desbloquear"
        android:textColor="@color/blanco" />

</FrameLayout>
