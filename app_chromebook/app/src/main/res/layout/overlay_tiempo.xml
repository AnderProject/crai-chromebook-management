<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/overlayRoot"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_overlay"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingStart="10dp"
    android:paddingTop="8dp"
    android:paddingEnd="16dp"
    android:paddingBottom="8dp">

    <!-- Estado COLAPSADO: solo un círculo con icono de reloj (blanco). -->
    <ImageView
        android:id="@+id/overlayColapsado"
        android:layout_width="44dp"
        android:layout_height="44dp"
        android:background="@drawable/bg_avatar"
        android:contentDescription="Tiempo restante"
        android:padding="9dp"
        android:src="@drawable/ic_reloj"
        android:visibility="gone" />

    <!-- Estado EXPANDIDO: foto + tiempo. -->
    <ImageView
        android:id="@+id/overlayFoto"
        android:layout_width="38dp"
        android:layout_height="38dp"
        android:layout_marginEnd="10dp"
        android:background="@drawable/bg_avatar"
        android:contentDescription="Foto del estudiante"
        android:padding="2dp"
        android:scaleType="centerCrop"
        android:src="@drawable/ic_avatar" />

    <LinearLayout
        android:id="@+id/overlayInfo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:alpha="0.75"
            android:text="Tiempo restante"
            android:textColor="@color/blanco"
            android:textSize="9sp" />

        <TextView
            android:id="@+id/overlayTiempo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:fontFamily="monospace"
            android:text="00:00:00"
            android:textColor="@color/blanco"
            android:textSize="18sp"
            android:textStyle="bold" />
    </LinearLayout>
</LinearLayout>
