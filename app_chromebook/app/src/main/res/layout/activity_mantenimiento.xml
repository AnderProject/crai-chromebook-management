<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/ambar">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:gravity="center"
        android:orientation="vertical"
        android:padding="32dp">

        <TextView
            android:id="@+id/mantIcono"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛠️"
            android:textSize="72sp" />

        <TextView
            android:id="@+id/txtCodigo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="12dp"
            android:text="CB-000"
            android:textColor="@color/blanco"
            android:textSize="34sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mantTitulo"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:text="@string/mant_titulo"
            android:textColor="@color/blanco"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/mantMensaje"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:gravity="center"
            android:text="@string/mant_mensaje"
            android:textColor="@color/blanco"
            android:textSize="16sp" />

        <TextView
            android:id="@+id/txtConexion"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:alpha="0.7"
            android:text=""
            android:textColor="@color/blanco"
            android:textSize="12sp" />
    </LinearLayout>

    <!-- Botón discreto para que el personal del CRAI configure con PIN -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnConfig"
        style="@style/Widget.MaterialComponents.Button.TextButton"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|end"
        android:layout_margin="8dp"
        android:alpha="0.6"
        android:text="⚙"
        android:textColor="@color/blanco"
        android:textSize="18sp" />

    <!-- Overlay de desconexión (encima de todo; se muestra/oculta en tiempo real) -->
    <include
        android:id="@+id/incDesconectado"
        layout="@layout/view_desconectado" />

</FrameLayout>
