<?xml version="1.0" encoding="utf-8"?>
<!-- Entrada de la pantalla nueva: aparece con fundido, sube un poco y crece
     suavemente desde 96% (sensación moderna, sin brusquedad). -->
<set xmlns:android="http://schemas.android.com/apk/res/android"
    android:interpolator="@android:interpolator/decelerate_quint">

    <alpha
        android:duration="420"
        android:fromAlpha="0.0"
        android:toAlpha="1.0" />

    <translate
        android:duration="480"
        android:fromYDelta="6%p"
        android:toYDelta="0" />

    <scale
        android:duration="480"
        android:fromXScale="0.96"
        android:fromYScale="0.96"
        android:toXScale="1.0"
        android:toYScale="1.0"
        android:pivotX="50%"
        android:pivotY="50%" />
</set>
